extends /include/bootstrap5

block beforehtml
  -
    title = 'Mifare 1k Access Bits'
    description = 'Calculator for Mifare Classic 1k Access Bits.'
    ogImage = 'https://i.imgur.com/hrUXvtO.png'
    ogImageWidth = 1200
    ogImageHeight = 600
    ogUrl = `${baseurl}mifare1k-acls.html`

block style
  style
    :sass
      [v-cloak]
        display: none
      .tr-striped
        background-color: rgba(0, 0, 0, .05)

block content
  #app
    nav-bar(baseurl=baseurl)
    .container.font-monospace.p-3.pb-5(v-cloak)
      header.text-center.mb-3
        h4.d-flex.justify-content-center.align-items-center.icon-link
          span.svgmask.svgmask-chameleon-ultra
          = title
      .input-group.mb-3
        span.input-group-text.justify-content-center ACLs (HEX)
        input.form-control(maxlength="8", v-model="ss.hexAcls", :class="[isValidAcls() ? 'is-valid' : 'is-invalid']")
        button.btn.btn-outline-secondary.icon-link(type="button", @click="ss.hexAcls = 'FF078069'")
          span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:restore.svg)")
        button.btn.btn-outline-secondary.icon-link(type="button", @click="btnCopy(ss.hexAcls)")
          span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:content-copy.svg)")
      table.table.table-sm.mb-2.table-bordered.text-center.fs-14px.ls-n1px
        thead
          tr
            th.align-middle(scope="col", rowspan="2") Data#[br]Block
            th(scope="col") Bits
            th(scope="col") Read
            th(scope="col") Write
            th(scope="col") Incr.
            th(scope="col") D./T./R.
          tr
            th(scope="col", colspan="5") Remarks
        tbody
          template(v-for="(acl, blk) in acls.slice(0, 3)", :key="blk")
            tr(:class="{'tr-striped': !(blk % 2)}", @click="btnDataAclPicker(blk)")
              td.align-middle(scope="col", rowspan="2") {{ blk }}
              td(scope="col") {{ acl >= 0 ? `00${acl.toString(2)}`.slice(-3) : '?' }}
              td(scope="col") {{ toPrivStr(DATA_BLK_READ, acl) }}
              td(scope="col") {{ toPrivStr(DATA_BLK_WRITE, acl) }}
              td(scope="col") {{ toPrivStr(DATA_BLK_INCR, acl) }}
              td(scope="col") {{ toPrivStr(DATA_BLK_DTR, acl) }}
            tr.ls-n2px(:class="{'tr-striped': !(blk % 2)}", @click="btnDataAclPicker(blk)")
              td(scope="col", colspan="5") {{ DATA_BLK_REMARKS[acl] ?? '?' }}
      ul.ps-4.text-muted.fs-14px.ls-n1px
        li Click table row to edit the Access Bits
        li Incr.: Increment
        li D./T./R.: Decrement/Transfer/Restore
      hr
      table.table.table-sm.mb-2.table-bordered.text-center.fs-14px.ls-n1px
        thead
          tr
            th.align-middle(scope="col", rowspan="2") Trailer#[br]Block#[br]Bits
            th(scope="col") Key A#[br]Read
            th(scope="col") Key A#[br]Write
            th(scope="col") ACLs#[br]Read
            th(scope="col") ACLs#[br]Write
            th(scope="col") Key B#[br]Read
            th(scope="col") Key B#[br]Write
          tr.ls-n2px
            th(scope="col", colspan="6") Remarks
        tbody.tr-striped(v-for="acl in acls.slice(3)")
          tr(@click="btnTrailerAclPicker")
            td.align-middle(rowspan="2") {{ acl >= 0 ? `00${acl.toString(2)}`.slice(-3) : '?' }}
            td {{ toPrivStr(TRAILER_BLK_A_READ, acl) }}
            td {{ toPrivStr(TRAILER_BLK_AB_WRITE, acl) }}
            td {{ toPrivStr(TRAILER_BLK_ACLS_READ, acl) }}
            td {{ toPrivStr(TRAILER_BLK_ACLS_WRITE, acl) }}
            td {{ toPrivStr(TRAILER_BLK_B_READ, acl) }}
            td {{ toPrivStr(TRAILER_BLK_AB_WRITE, acl) }}
          tr.ls-n2px(@click="btnTrailerAclPicker")
            td(colspan="6") {{ TRAILER_BLK_REMARKS[acl] ?? '?' }}
      ul.ps-4.text-muted.fs-14px.ls-n1px
        li If key B is readable data, it cannot serve for authentication. Please refer to NXP #[a(target="_blank", href="https://www.nxp.com/docs/en/data-sheet/MF1S50YYX_V1.pdf") MF1S50YYX_V1.pdf] for more information.
      .alert.alert-warning.mb-3.fs-14px.ls-n1px
        h6.alert-heading.icon-link
          span.svgmask.fs-1dot2em(style="--svgmask-url: url(https://api.iconify.design/mdi:alert-outline.svg)")
          | Warning
        div Writing an incorrect value to the access condition bits will permanently lock the sector.
    .modal.fade(data-bs-backdrop="static", data-bs-keyboard="false", tabindex="-1", ref="dataAclPickerModal")
      .modal-dialog.modal-dialog-centered.modal-xl
        .modal-content
          .modal-header
            h5.modal-title.icon-link.ls-n1px
              span.svgmask.fs-1dot2em(style="--svgmask-url: url(https://api.iconify.design/mdi:content-save-outline.svg)")
              | New ACLs for Block {{ dataAclPicker.block }}
            button.btn-close(type="button", data-bs-dismiss="modal", aria-label="Close")
          .modal-body
            table.table.table-sm.mb-2.table-bordered.text-center.fs-14px.ls-n1px
              thead
                tr
                  th.align-middle(scope="col", rowspan="2") Bits
                  th(scope="col") Read
                  th(scope="col") Write
                  th(scope="col") Incr.
                  th(scope="col") D./T./R.
                tr
                  th(scope="col", colspan="4") Remarks
              tbody
                template(v-for="acl in aclRange", :key="acl")
                  tr(:class="{'tr-striped': !(acl % 2), 'table-success': acl === dataAclPicker.acl}", @click="dataAclPicker.cb?.(acl)")
                    td.align-middle(scope="col", rowspan="2") {{ `00${acl.toString(2)}`.slice(-3) }}
                    td(scope="col") {{ toPrivStr(DATA_BLK_READ, acl) }}
                    td(scope="col") {{ toPrivStr(DATA_BLK_WRITE, acl) }}
                    td(scope="col") {{ toPrivStr(DATA_BLK_INCR, acl) }}
                    td(scope="col") {{ toPrivStr(DATA_BLK_DTR, acl) }}
                  tr.ls-n2px(:class="{'tr-striped': !(acl % 2), 'table-success': acl === dataAclPicker.acl}", @click="dataAclPicker.cb?.(acl)")
                    td(scope="col", colspan="4") {{ DATA_BLK_REMARKS[acl] ?? '?' }}
            small.text-muted.form-text Click table row to pick new ACL. If key B is readable data, it cannot serve for authentication.
    .modal.fade(data-bs-backdrop="static", data-bs-keyboard="false", tabindex="-1", ref="trailerAclPickerModal")
      .modal-dialog.modal-dialog-centered.modal-xl
        .modal-content
          .modal-header
            h5.modal-title.icon-link.ls-n1px
              span.svgmask.fs-1dot2em(style="--svgmask-url: url(https://api.iconify.design/mdi:content-save-outline.svg)")
              | New ACLs for Trailer Block
            button.btn-close(type="button", data-bs-dismiss="modal", aria-label="Close")
          .modal-body
            table.table.table-sm.mb-2.table-bordered.text-center.fs-14px.ls-n1px
              thead
                tr
                  th.align-middle(scope="col", rowspan="2") Trailer#[br]Block#[br]Bits
                  th(scope="col") Key A#[br]Read
                  th(scope="col") Key A#[br]Write
                  th(scope="col") ACLs#[br]Read
                  th(scope="col") ACLs#[br]Write
                  th(scope="col") Key B#[br]Read
                  th(scope="col") Key B#[br]Write
                tr.ls-n2px
                  th(scope="col", colspan="6") Remarks
              tbody
                template(v-for="acl in aclRange", :key="acl")
                  tr(:class="{'tr-striped': !(acl % 2), 'table-success': acl === trailerAclPicker.acl}", @click="trailerAclPicker.cb?.(acl)")
                    td.align-middle(rowspan="2") {{ `00${acl.toString(2)}`.slice(-3) }}
                    td {{ toPrivStr(TRAILER_BLK_A_READ, acl, acl) }}
                    td {{ toPrivStr(TRAILER_BLK_AB_WRITE, acl, acl) }}
                    td {{ toPrivStr(TRAILER_BLK_ACLS_READ, acl, acl) }}
                    td {{ toPrivStr(TRAILER_BLK_ACLS_WRITE, acl, acl) }}
                    td {{ toPrivStr(TRAILER_BLK_B_READ, acl, acl) }}
                    td {{ toPrivStr(TRAILER_BLK_AB_WRITE, acl, acl) }}
                  tr.ls-n2px(:class="{'tr-striped': !(acl % 2), 'table-success': acl === trailerAclPicker.acl}", @click="trailerAclPicker.cb?.(acl)")
                    td(scope="col", colspan="6") {{ TRAILER_BLK_REMARKS[acl] ?? '?' }}
            small.text-muted.form-text Click table row to pick new ACL. If key B is readable data, it cannot serve for authentication.
  include /include/bootstrap5-navbar-content

block script
  script(type="module").
    import { Buffer, ChameleonUltra } from 'chameleon-ultra.js'
    import { Modal } from 'bootstrap'
    import _ from 'lodash'
    import { computed, createApp, reactive, useTemplateRef, watch } from 'vue'
    import { loadPageStorage, savePageStorage, swalFire } from '@app/js/bootstrap5-utils.mjs'
    import NavBar from '@app/js/bootstrap5-navbar.mjs'

    const toHex = buf => _.toUpper(buf.toString('hex'))
    const ACLS_BIT_OFFSET = [
      [15, 19], // !C0, C0
      [3, 23], // !B0, B0
      [7, 11], // !A0, A0
    ]
    const ACL_RANGE = [0, 1, 2, 3, 4, 5, 6, 7]
    const DATA_BLK_READ = [3, 3, 3, 1, 3, 1, 3, 0]
    const DATA_BLK_WRITE = [3, 0, 0, 1, 1, 0, 1, 0]
    const DATA_BLK_INCR = [3, 0, 0, 0, 0, 0, 1, 0]
    const DATA_BLK_DTR = [3, 3, 0, 0, 0, 0, 3, 0]
    const DATA_BLK_REMARKS = [
      'Value block. Factory default.',
      'Value block.',
      '　',
      '　',
      '　',
      '　',
      'Value block.',
      'No privileges.',
    ]
    const TRAILER_BLK_A_READ = [0, 0, 0, 0, 0, 0, 0, 0]
    const TRAILER_BLK_AB_WRITE = [2, 2, 0, 1, 1, 0, 0, 0]
    const TRAILER_BLK_ACLS_READ = [2, 2, 2, 3, 3, 3, 3, 3]
    const TRAILER_BLK_ACLS_WRITE = [0, 2, 0, 1, 0, 1, 0, 0]
    const TRAILER_BLK_B_READ = [2, 2, 2, 0, 0, 0, 0, 0]
    const TRAILER_BLK_REMARKS = [
      'Key B is readable data.',
      'Key B is readable data. Factory default.',
      'Key B is readable data.',
      '　',
      '　',
      '　',
      '　',
      '　',
    ]

    window.vm = createApp({
      components: { NavBar },
      setup () {
        const ss = reactive({ hexAcls: 'FF078069' })
        const dataAclPicker = reactive({ block: 0, cb: null, acl: -1 })
        const trailerAclPicker = reactive({ cb: null, acl: -1 })

        const dataAclPickerModalRef = useTemplateRef('dataAclPickerModal')
        const trailerAclPickerModalRef = useTemplateRef('trailerAclPickerModal')

        loadPageStorage(sessionStorage, ss)
        watch(ss, () => { savePageStorage(sessionStorage, ss) }, { deep: true })

        const acls = computed(() => {
          try {
            const buf = Buffer.from(ss.hexAcls, 'hex')
            if (buf.length < 3) throw new Error('invalid length')
            return _.times(4, blk => _.sum(_.times(3, i => buf.readBitMSB(ACLS_BIT_OFFSET[i][1] - blk) << i)))
          } catch (err) {
            return [-1, -1, -1, -1]
          }
        })

        async function btnCopy (text) {
          try {
            text = `${text}`
            const clipboard = navigator.clipboard
            if (!clipboard) throw new Error('Clipboard API is not supported.')
            await clipboard.writeText(text)
            await swalFire({ icon: 'success', title: `${text.length} bytes copied.` })
          } catch (err) {
            await swalFire({ icon: 'error', title: 'Copy failed', text: err.message })
          }
        }

        async function btnDataAclPicker (block) {
          const modalEl = dataAclPickerModalRef.value
          const modal = Modal.getOrCreateInstance(modalEl)
          const newVal = await new Promise(resolve => {
            Object.assign(dataAclPicker, { block, cb: resolve, acl: acls.value?.[block] ?? -1 })
            modalEl.addEventListener('hidden.bs.modal', () => resolve(), { once: true })
            modal.show()
          })
          modal.hide()
          dataAclPicker.cb = null
          if (_.isNil(newVal)) return
          setNewBlkAcl(block, newVal)
        }

        async function btnTrailerAclPicker () {
          const modalEl = trailerAclPickerModalRef.value
          const modal = Modal.getOrCreateInstance(modalEl)
          const newVal = await new Promise(resolve => {
            Object.assign(trailerAclPicker, { cb: resolve, acl: acls.value?.[3] ?? -1 })
            modalEl.addEventListener('hidden.bs.modal', () => resolve(), { once: true })
            modal.show()
          })
          modal.hide()
          trailerAclPicker.cb = null
          if (_.isNil(newVal)) return
          setNewBlkAcl(3, newVal)
        }

        function toPrivStr (tbl, acl, trailerAcl) {
          trailerAcl ??= acls.value?.[3] ?? -1
          if (trailerAcl < 0 || acl < 0) return '?'
          return ['　', 'Ⓑ', 'Ⓐ', 'Ⓐ Ⓑ'][tbl[acl] & (trailerAcl < 3 ? 0b10 : 0b11)]
        }

        function setNewBlkAcl (blk1, newAcl) {
          const aclsArr = [...acls.value]
          aclsArr[blk1] = newAcl // set new ACL
          for (const [i, acl] of _.entries([0, 0, 0, 1])) {
            if (!_.inRange(aclsArr[i], 8)) aclsArr[i] = acl
          }

          const buf1 = Buffer.from(ss.hexAcls, 'hex')
          const buf2 = Buffer.alloc(4)
          if (buf1.length === 4) buf2[3] = buf1[3] // copy user data
          for (let blk = 0; blk < 4; blk++) {
            const acl = aclsArr[blk]
            for (let i = 0; i < 3; i++) buf2.writeBitMSB(1, ACLS_BIT_OFFSET[i][(acl >>> i) & 1] - blk)
          }
          ss.hexAcls = toHex(buf2)
        }

        function isValidAcls (hexAcls) {
          hexAcls ??= ss.hexAcls
          const buf = Buffer.from(hexAcls, 'hex')
          if (!_.includes([3, 4], buf.length)) return false
          return ChameleonUltra.mf1IsValidAcl(buf)
        }

        return {
          ss,
          dataAclPicker,
          trailerAclPicker,
          aclRange: ACL_RANGE,
          acls,
          DATA_BLK_READ,
          DATA_BLK_WRITE,
          DATA_BLK_INCR,
          DATA_BLK_DTR,
          DATA_BLK_REMARKS,
          TRAILER_BLK_A_READ,
          TRAILER_BLK_AB_WRITE,
          TRAILER_BLK_ACLS_READ,
          TRAILER_BLK_ACLS_WRITE,
          TRAILER_BLK_B_READ,
          TRAILER_BLK_REMARKS,
          btnCopy,
          btnDataAclPicker,
          btnTrailerAclPicker,
          toPrivStr,
          isValidAcls,
        }
      },
    }).mount('#app')
