extends /include/bootstrap5

block beforehtml
  -
    title = 'Xiaomi Watch Clone Tool'
    description = 'A tool for Xiaomi Watch to clone encrypted Mifare Classic tag.'
    ogImage = 'https://i.imgur.com/M39Y0Be.png'
    ogImageWidth = 1200
    ogImageHeight = 600
    ogUrl = `${baseurl}mifare-xiaomi.html`

block style
  style
    :sass
      [v-cloak]
        display: none
      .input-group-text
        width: 80px

block content
  #app
    nav-bar(baseurl=baseurl)
    .container.font-monospace.p-3.pb-5(v-cloak)
      header.text-center.mb-3
        h4.d-flex.justify-content-center.align-items-center.icon-link
          span.svgmask.svgmask-chameleon-ultra
          = title
      include /include/bootstrap5-adapter-content
      .card.shadow.mb-2
        h6.card-header ① Mifare Dump
        .card-body.overflow-hidden
          p.fs-14px Click "Import" button to import a mifare dump exported from #[a(target="_blank", href=`${baseurl}mifare1k.html`) mifare1k.html] or other tools like MCT, Proxmark3. Keys in dump will be used to sync with Xiaomi Watch. Dump will be deleted after page closed.
          input.d-none(type="file", ref="dumpImportInput", @change="dumpImport?.cb?.($event.target.files[0])", @cancel="dumpImport?.cb?.()")
          .input-group.input-group-sm.mb-2.was-validated
            label.input-group-text.justify-content-center(for="ss-uid") UID
            input.form-control.form-control-sm#ss-uid(pattern="[\\dA-Fa-f]{8}([\\dA-Fa-f]{6})?([\\dA-Fa-f]{6})?", maxlength="20", placeholder="Hex format of UID", required, v-model="ss.uid")
            button.btn.btn-outline-secondary.icon-link(type="button", @click="ss.uid = ''")
              span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:close.svg)")
          .input-group.input-group-sm.mb-2.was-validated
            label.input-group-text.justify-content-center(for="ss-atqa") ATQA
            input.form-control.form-control-sm#ss-atqa(pattern="[\\dA-Fa-f]{4}", maxlength="4", placeholder="Hex format of ATQA", required, v-model="ss.atqa")
            button.btn.btn-outline-secondary.icon-link(type="button", @click="ss.atqa = ''")
              span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:close.svg)")
          .input-group.input-group-sm.mb-2.was-validated
            label.input-group-text.justify-content-center(for="ss-sak") SAK
            input.form-control.form-control-sm#ss-sak(pattern="[\\dA-Fa-f]{2}", maxlength="2", placeholder="Hex format of SAK", required, v-model="ss.sak")
            button.btn.btn-outline-secondary.icon-link(type="button", @click="ss.sak = ''")
              span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:close.svg)")
          .row.g-2.mb-2
            .col
              button.btn.w-100.btn-outline-success.icon-link.justify-content-center(type="button", @click="btnImportDump")
                span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:file-import-outline.svg)")
                | Import
            .col
              button.btn.w-100.btn-outline-primary.icon-link.justify-content-center(type="button", @click="btnExportDump")
                span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:file-export-outline.svg)")
                | Export
          button.btn.btn-sm.w-100.btn-outline-danger.icon-link.justify-content-center.ls-n1px.mb-2(type="button", @click="btnNewDump")
            span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:restore.svg)")
            | New dump
      .card.shadow.mb-2
        h6.card-header ② ChameleonUltra Emulate
        .card-body.overflow-hidden
          p.fs-14px Choose a slot and click the "Emulate" button to emulate as non-encrypted tag. Then use Xiaomi Watch to clone the ChameleonUltra.
          .input-group.input-group-sm.mb-2
            label.input-group-text.justify-content-center(for="ss-slot") Slot
            select.form-select.form-select-sm#ss-slot(v-model.number="ss.slot")
              option(v-for="i of 8", :key="i", :value="i - 1") Slot {{ i }}
          button.btn.w-100.btn-outline-success.icon-link.justify-content-center.mb-2(type="button", @click="btnWriteEmuBlock0")
            span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:login.svg)")
            | Emulate
      .card.shadow.mb-2
        h6.card-header ③ Sync with Xiaomi Watch
        .card-body.overflow-hidden
          p.fs-14px.mb-2 After clone, click "Write" button to write original dump to Xiaomi Watch.
          .form-check.mb-2
            input.form-check-input#ss-checkUidBeforeWrite(type="checkbox", v-model="ss.checkUidBeforeWrite")
            label.form-check-label(for="ss-checkUidBeforeWrite") Verify UID before write
          button.btn.w-100.btn-outline-primary.icon-link.justify-content-center.mb-2(type="button", @click="btnGen2Write")
            span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:tag-arrow-up-outline.svg)")
            | Write
        .card-body.overflow-hidden.border-top
          p.fs-14px.mb-2 Click "Verify" button to compare between dump and Xiaomi Watch (skip block 0).
          button.btn.w-100.btn-outline-success.icon-link.justify-content-center.mb-2(type="button", @click="btnGen2Verify")
            span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:tag-check-outline.svg)")
            | Verify
        .card-body.overflow-hidden.border-top
          p.fs-14px.mb-2 Click "Read" button to read from Xiaomi Watch (skip block 0). After read, you can click "Export" or "Write" button.
          button.btn.w-100.btn-outline-info.icon-link.justify-content-center.mb-2(type="button", @click="btnGen2Read")
            span.svgmask.fs-1dot5em(style="--svgmask-url: url(https://api.iconify.design/mdi:tag-arrow-down-outline.svg)")
            | Read
    .modal.fade(tabindex="-1", ref="dumpExportModal")
      .modal-dialog.modal-dialog-centered.modal-xl
        .modal-content
          .modal-header
            h5.modal-title.icon-link
              span.svgmask.fs-1dot2em(style="--svgmask-url: url(https://api.iconify.design/mdi:file-export-outline.svg)")
              | Export Dump
            button.btn-close(type="button", data-bs-dismiss="modal", aria-label="Close")
          .modal-body
            a.btn.w-100.btn-outline-primary.mb-2.text-start(
              :download="dumpExport.json.download",
              :href="dumpExport.json.href",
              target="_blank")
              .my-1 {{ dumpExport.json.download }}
              h6.text-muted.mb-1 Click to download as JSON format. This format can be used in Proxmark3 and Chameleon Mini GUI.
            a.btn.w-100.btn-outline-primary.mb-2.text-start(
              :download="dumpExport.bin.download",
              :href="dumpExport.bin.href",
              target="_blank")
              .my-1 {{ dumpExport.bin.download }}
              h6.text-muted.mb-1 Click to download as BIN format. This format can be used in Proxmark3, libnfc, mfoc...
            a.btn.w-100.btn-outline-primary.mb-2.text-start(
              :download="dumpExport.eml.download",
              :href="dumpExport.eml.href",
              target="_blank")
              .my-1 {{ dumpExport.eml.download }}
              h6.text-muted.mb-1 Click to download as EML format. This format can be used in Proxmark3 emulator.
            a.btn.w-100.btn-outline-primary.text-start(
              :download="dumpExport.mct.download",
              :href="dumpExport.mct.href",
              target="_blank")
              .my-1 {{ dumpExport.mct.download }}
              h6.text-muted.mb-1 Click to download as MCT format. This format can be used in Mifare Classic Tool.
  include /include/bootstrap5-navbar-content

block script
  script(type="module").
    import { Buffer, ChameleonUltra, DeviceMode, FreqType, TagType } from 'chameleon-ultra.js'
    import Debug from 'chameleon-ultra.js/plugin/Debug'
    import WebbleAdapter from 'chameleon-ultra.js/plugin/WebbleAdapter'
    import WebserialAdapter from 'chameleon-ultra.js/plugin/WebserialAdapter'
    import { Modal } from 'bootstrap'
    import JSON5 from 'json5'
    import _ from 'lodash'
    import { computed, createApp, nextTick, reactive, useTemplateRef, watch } from 'vue'
    import { btnAdapterTips, loadPageStorage, savePageStorage, showLoading, swalConfirm, swalFire } from '@app/js/bootstrap5-utils.mjs'
    import NavBar from '@app/js/bootstrap5-navbar.mjs'

    const ultraUsb = new ChameleonUltra()
    ultraUsb.use(new Debug())
    ultraUsb.use(new WebserialAdapter())
    const ultraBle = new ChameleonUltra()
    ultraBle.use(new Debug())
    ultraBle.use(new WebbleAdapter())

    const toHex = buf => _.toUpper(buf.toString('hex'))
    const WELL_KNOWN_KEYS = [Buffer.from('FFFFFFFFFFFF', 'hex')]
    const isMf1MagicBlock0 = buf => Buffer.isBuffer(buf) && buf.length >= 16 && _.includes([0x08, 0x88], buf[5]) && toHex(buf.subarray(6, 8)) === '0400' && buf[4] === buf.subarray(0, 4).xor()

    window.vm = createApp({
      components: { NavBar },
      setup () {
        const ls = reactive({ adapter: 'ble' })
        const ss = reactive({
          atqa: '0004',
          checkUidBeforeWrite: true,
          dump: null,
          sak: '08',
          slot: 0,
          uid: 'DEADBEEF',
        })
        const dumpImport = reactive({ cb: null })
        const dumpExport = reactive({
          json: { download: '', href: '' },
          bin: { download: '', href: '' },
          eml: { download: '', href: '' },
          mct: { download: '', href: '' },
        })

        const dumpImportInputRef = useTemplateRef('dumpImportInput')
        const dumpExportModalRef = useTemplateRef('dumpExportModal')

        loadPageStorage(localStorage, ls)
        watch(ls, () => { savePageStorage(localStorage, ls) }, { deep: true })

        // ss.dump is a Buffer, JSON5 can't (de)serialize it directly, so it's stored as base64url
        try {
          const saved = JSON5.parse(sessionStorage.getItem(location.pathname))
          if (_.isObject(saved)) {
            if (!_.isNil(saved.dump)) {
              try {
                saved.dump = Buffer.from(saved.dump, 'base64url')
              } catch (err) {
                delete saved.dump
              }
            }
            _.merge(ss, saved)
          }
        } catch (err) {}
        watch(ss, () => {
          const saved = { ...ss }
          if (Buffer.isBuffer(saved.dump)) saved.dump = saved.dump.toString('base64url')
          sessionStorage.setItem(location.pathname, JSON5.stringify(saved))
        }, { deep: true })

        const ultra = computed(() => ls.adapter === 'usb' ? ultraUsb : ultraBle)

        const logError = err => { ultra.value.emitter.emit('error', err) }

        function mf1GenEmptyDump (antiColl) {
          antiColl ??= {
            atqa: Buffer.from(ss.atqa, 'hex').toReversed(),
            sak: Buffer.from(ss.sak, 'hex'),
            uid: Buffer.from(ss.uid, 'hex'),
          }
          return ChameleonUltra.mf1GenEmptyDump({ ...antiColl, tagType: TagType.MIFARE_1024 })
        }

        if (!Buffer.isBuffer(ss.dump)) ss.dump = mf1GenEmptyDump()

        async function btnImportDump () {
          try {
            showLoading({ text: 'Importing' })
            const file = await new Promise(resolve => {
              dumpImport.cb = resolve
              const inputEl = dumpImportInputRef.value
              inputEl.value = ''
              inputEl.click()
            })
            if (_.isNil(file)) throw new Error('No file selected')
            if (file.size > 1e6) throw new Error(`File size too large: ${file.size} bytes`)
            const dotIdx = file.name.lastIndexOf('.')
            if (dotIdx === -1) throw new Error('Invalid file name')
            const ext = _.toLower(file.name.slice(dotIdx + 1))
            const buf = new Buffer(await file.arrayBuffer())
            const res = {
              dump: null,
            }
            switch (ext) {
              case 'bin': {
                res.dump = buf
                break
              }
              case 'json':
              case 'json5': {
                const card = ChameleonUltra.mf1DumpFromPm3Json(buf)
                _.merge(res, {
                  uid: toHex(card.uid),
                  atqa: toHex(card.atqa.toReversed()),
                  sak: toHex(card.sak),
                  dump: card?.body,
                })
                break
              }
              case 'eml': {
                res.dump = ChameleonUltra.mf1DumpFromEml(buf)
                break
              }
              case 'mct': {
                res.dump = ChameleonUltra.mf1DumpFromMct(buf)
                break
              }
              default:
                throw new Error(`Unsupported file extension: ${ext}`)
            }
            if (!Buffer.isBuffer(res.dump)) throw new Error('Failed to import dump')
            if (res.dump.length !== 1024) throw new Error(`dump size invalid: ${res.dump?.length} bytes`)

            // try anti-collision
            if (_.isNil(res.uid) && isMf1MagicBlock0(res.dump)) {
              _.merge(res, {
                atqa: toHex(res.dump.subarray(6, 8).toReversed()),
                sak: toHex(res.dump.subarray(5, 6)),
                uid: toHex(res.dump.subarray(0, 4)),
              })
            }
            Object.assign(ss, res)

            await swalFire({ icon: 'success', title: 'Import success', text: 'Please verify import result. Invalid bytes has been replace with 0x00.' })
          } catch (err) {
            logError(err)
            await swalFire({ icon: 'error', title: 'Import failed', text: err.message })
          }
        }

        async function btnExportDump () {
          const dump = ss.dump
          const atqa = Buffer.from(ss.atqa, 'hex').toReversed()
          const sak = Buffer.from(ss.sak, 'hex')
          const uid = Buffer.from(ss.uid, 'hex')
          const strUid = toHex(uid)

          // json
          const json = ChameleonUltra.mf1DumpToPm3Json({ atqa, body: dump, sak, uid })
          dumpExport.json = {
            href: URL.createObjectURL(new Blob([JSON.stringify(json, null, 2)], { type: 'application/octet-stream' })),
            download: `hf-mf-${strUid}.json`,
          }

          // bin
          dumpExport.bin = {
            href: URL.createObjectURL(new Blob([dump], { type: 'application/octet-stream' })),
            download: `hf-mf-${strUid}.bin`,
          }

          // eml
          const eml = ChameleonUltra.mf1DumpToEml({ body: dump })
          dumpExport.eml = {
            href: URL.createObjectURL(new Blob([eml], { type: 'application/octet-stream' })),
            download: `hf-mf-${strUid}.eml`,
          }

          // mct
          const mct = ChameleonUltra.mf1DumpToMct({ body: dump })
          dumpExport.mct = {
            href: URL.createObjectURL(new Blob([mct], { type: 'application/octet-stream' })),
            download: `hf-mf-${strUid}.mct`,
          }

          await nextTick() // wait for DOM update
          Modal.getOrCreateInstance(dumpExportModalRef.value).show()
        }

        async function btnNewDump () {
          try {
            const msg1 = 'Mifare dump will be REPLACED! Continue?'
            if (!await swalConfirm(msg1, 'Yes', 'Cancel')) return
            ss.dump = mf1GenEmptyDump()
          } catch (err) {
            logError(err)
            await swalFire({ icon: 'error', title: 'Reset failed', text: err.message })
          }
        }

        async function btnWriteEmuBlock0 () {
          try {
            const { atqa, dump, sak, slot, uid } = ss
            ultra.value.emitter.emit('debug', 'web', JSON.stringify({ atqa, dump, sak, slot, uid }))
            const slotName = await ultra.value.cmdSlotGetFreqName(slot, FreqType.HF) ?? '(no name)'
            const msg1 = `The hf data of slot ${slot + 1} "${slotName}" will be REPLACE! Continue?`
            if (!await swalConfirm(msg1, 'Yes', 'Cancel')) return
            showLoading({ text: 'Emulating...' })
            await ultra.value.cmdChangeDeviceMode(DeviceMode.TAG)
            await ultra.value.slotChangeTagTypeAndActive(slot, TagType.MIFARE_1024) // reset slot
            await ultra.value.cmdSlotSetFreqName(slot, FreqType.HF, `xiaomi_${uid}`)
            // set anti-coll
            const tag = {
              atqa: Buffer.from(atqa, 'hex').toReversed(),
              sak: Buffer.from(sak, 'hex'),
              uid: Buffer.from(uid, 'hex').slice(-4),
            }
            await ultra.value.cmdMf1SetAntiCollMode(false)
            await ultra.value.cmdHf14aSetAntiCollData(tag)
            await ultra.value.cmdMf1EmuWriteBlock(0, dump.subarray(0, 16)) // set block0
            await ultra.value.cmdSlotSaveSettings()
            await swalFire({ icon: 'success', title: 'Emulate successfully!' })
          } catch (err) {
            logError(err)
            await swalFire({ icon: 'error', title: 'Failed to emulate tag.', text: err.message })
          }
        }

        async function btnGen2Write () {
          try {
            const { checkUidBeforeWrite, dump, uid } = ss
            const msg1 = 'Mifare Data in Xiaomi Watch will be REPLACE! Continue?'
            if (!await swalConfirm(msg1, 'Yes', 'Cancel')) return
            if (checkUidBeforeWrite) {
              const antiColl = await mfReadAntiColl()
              if (antiColl.uid !== uid) throw new Error(`UID is different, read = ${toHex(antiColl.uid)}`)
            }
            const genSwalCfg = i => ({
              html: `<div class="d-flex flex-column"><div class="progress mb-2"><div class="progress-bar progress-bar-striped" role="progressbar" style="width: ${i / 16 * 100}%"></div></div><div class="d-flex justify-content-between"><span>Writing Mifare / Gen2:</span><span>${i} / 16</span></div></div>`,
            })
            showLoading(genSwalCfg(0))
            const failed = []
            for (let i = 0; i < 16; i++) {
              try {
                const sectorData = dump.subarray(i * 64).subarray(0, 64)
                const keys = [
                  ..._.map([0, 10], pos => sectorData.subarray(pos - 16).subarray(0, 6)),
                  ...WELL_KNOWN_KEYS,
                ]
                const { success } = await ultra.value.mf1WriteSectorByKeys(i, keys, sectorData)
                for (let j = 0; j < 4; j++) if (!success[j]) failed.push(i * 4 + j)
              } catch (err) {
                if (!ultra.value.isConnected()) throw err
                logError(err)
                for (let j = 0; j < 4; j++) failed.push(i * 4 + j)
              }
              showLoading(genSwalCfg(i + 1))
            }
            await ultra.value.cmdChangeDeviceMode(DeviceMode.TAG)
            _.pull(failed, 0) // ignore error of block 0
            if (failed.length !== 0) throw new Error(`${failed.length} blocks failed: ${failed.join(',')}`)
            await swalFire({ icon: 'success', title: 'Write success' })
          } catch (err) {
            logError(err)
            await swalFire({ icon: 'error', title: 'Write failed', text: err.message })
          }
        }

        async function mfReadAntiColl () {
          const antiColl = {}
          showLoading({ text: 'Reading anti-collision...' })
          const tag1 = _.first(await ultra.value.cmdHf14aScan())
          _.merge(antiColl, {
            atqa: toHex(tag1.atqa.toReversed()),
            sak: toHex(tag1.sak),
            uid: toHex(tag1.uid),
          })
          return antiColl
        }

        async function mfGen2Read () {
          const res = {}

          // read anti-collision
          _.merge(res, await mfReadAntiColl())
          ultra.value.emitter.emit('debug', 'web', `res = ${JSON.stringify(res)}`)

          const genSwalCfg = i => ({
            html: `<div class="d-flex flex-column"><div class="progress mb-2"><div class="progress-bar progress-bar-striped" role="progressbar" style="width: ${i / 16 * 100}%"></div></div><div class="d-flex justify-content-between"><span>Reading Mifare / Gen2:</span><span>${i} / 16</span></div></div>`,
          })
          showLoading(genSwalCfg(0))
          const failed = []
          const newDump = mf1GenEmptyDump({
            atqa: Buffer.from(res.atqa, 'hex').toReversed(),
            sak: Buffer.from(res.sak, 'hex'),
            uid: Buffer.from(res.uid, 'hex'),
          })
          const oldDump = ss.dump
          for (let i = 0; i < 16; i++) {
            try {
              const oldSectorData = oldDump.subarray(i * 64).subarray(0, 64)
              const keys = [
                ..._.map([0, 10], pos => oldSectorData.subarray(pos - 16).subarray(0, 6)),
                ...WELL_KNOWN_KEYS,
              ]
              const { data: newSectorData, success } = await ultra.value.mf1ReadSectorByKeys(i, keys)
              newDump.set(newSectorData, i * 64)
              for (let j = 0; j < 4; j++) if (!success[j]) failed.push(i * 4 + j)
            } catch (err) {
              if (!ultra.value.isConnected()) throw err
              for (let j = 0; j < 4; j++) failed.push(i * 4 + j)
              logError(err)
            }
            showLoading(genSwalCfg(i + 1))
          }
          await ultra.value.cmdChangeDeviceMode(DeviceMode.TAG)
          res.dump = newDump
          _.pull(failed, 0) // ignore error of block 0
          if (failed.length !== 0) throw new Error(`${failed.length} blocks failed: ${failed.join(',')}`)
          return res
        }

        async function btnGen2Verify () {
          try {
            const dump = ss.dump
            const other = await mfGen2Read()
            if (other.uid !== ss.uid) throw new Error(`UID is different, read = ${toHex(other.uid)}`)
            const diffs = []
            for (let i = 1; i < 64; i++) {
              const [blk1, blk2] = _.map([dump, other.dump], buf => buf.subarray(i * 16).subarray(0, 16))
              if (!blk1.equals(blk2)) diffs.push(i)
            }
            if (diffs.length !== 0) throw new Error(`${diffs.length} blocks are different: ${diffs.join(',')}`)
            await swalFire({ icon: 'success', title: 'All blocks is equal.' })
          } catch (err) {
            logError(err)
            await swalFire({ icon: 'error', title: 'Verify failed', text: err.message })
          }
        }

        async function btnGen2Read () {
          try {
            const other = await mfGen2Read()
            Object.assign(ss, other)
            await swalFire({ icon: 'success', title: 'Read success' })
          } catch (err) {
            logError(err)
            await swalFire({ icon: 'error', title: 'Read failed', text: err.message })
          }
        }

        return {
          ls,
          ss,
          dumpImport,
          dumpExport,
          ultra,
          btnAdapterTips,
          btnImportDump,
          btnExportDump,
          btnNewDump,
          btnWriteEmuBlock0,
          btnGen2Write,
          btnGen2Verify,
          btnGen2Read,
          showLoading,
          swalFire,
        }
      },
    }).mount('#app')
