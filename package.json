{
  "author": "taichunmin <taichunmin@gmail.com>",
  "browser": "./dist/index.global.js",
  "description": "A JavaScript SDK for ChameleonUltra using Web Bluetooth, Web Serial and SerialPort.",
  "homepage": "https://taichunmin.idv.tw/chameleon-ultra.js/",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "name": "chameleon-ultra.js",
  "packageManager": "yarn@1.22.22",
  "type": "commonjs",
  "version": "0.4.7",
  "bugs": {
    "url": "https://github.com/taichunmin/chameleon-ultra.js/issues"
  },
  "contributors": [
    {
      "email": "taichunmin@gmail.com",
      "name": "Chunmin Tai",
      "url": "https://taichunmin.idv.tw"
    }
  ],
  "dependencies": {
    "@taichunmin/buffer": "^0.13.16",
    "@taichunmin/crc": "^0.0.22",
    "debug": "^4.4.3",
    "jszip": "^3.10.1",
    "lodash-es": "^4.18.1",
    "serialport": "^13.0.0",
    "web-serial-polyfill": "^1.0.15",
    "webbluetooth": "^3.7.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/debug": "^4.1.13",
    "@types/finalhandler": "^1.2.4",
    "@types/html-minifier": "^4.0.6",
    "@types/json5": "^2.2.0",
    "@types/livereload": "^0.9.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.1",
    "@types/pug": "^2.0.10",
    "@types/serve-static": "^2.2.0",
    "@types/uglify-js": "^3.17.5",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.10",
    "chokidar": "^5.0.0",
    "concurrently": "^10.0.3",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "esbuild-plugins-node-modules-polyfill": "^1.8.2",
    "eslint": "^9",
    "eslint-plugin-pug": "^1.2.7",
    "eslint-plugin-tsdoc": "^0.5.2",
    "fast-glob": "^3.3.3",
    "finalhandler": "^2.1.1",
    "globals": "^17.7.0",
    "html-minifier": "^4.0.0",
    "json5": "^2.2.3",
    "jstransformer-sass": "^1.0.0",
    "livereload": "^0.10.3",
    "mkdirp": "^3.0.1",
    "neostandard": "^0.13.0",
    "node-watch": "^0.7.4",
    "nodemon": "^3.1.14",
    "pug": "^3.0.4",
    "rimraf": "^6.1.3",
    "serve-static": "^2.2.1",
    "supports-color": "^10.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "type-fest": "^5.8.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-ga": "^1.1.1",
    "typedoc-plugin-llms-txt": "^0.1.2",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typedoc-plugin-missing-exports": "^4.1.4",
    "typedoc-plugin-rename-defaults": "^0.7.3",
    "typescript": "^6",
    "uglify-js": "^3.19.3",
    "utility-types": "^3.11.0",
    "vitest": "^4.1.10"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.ts"
      },
      "script": "./dist/index.global.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./*": {
      "types": {
        "import": "./dist/*.d.mts",
        "require": "./dist/*.d.ts"
      },
      "script": "./dist/*.global.js",
      "import": "./dist/*.mjs",
      "require": "./dist/*.js"
    }
  },
  "keywords": [
    "browser",
    "chameleon-ultra",
    "chrome",
    "COM",
    "mifare classic",
    "nfc",
    "RFID",
    "serial port",
    "serial",
    "serialport",
    "UART",
    "web bluetooth",
    "web serial",
    "web-bluetooth-api",
    "web-serial-api"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taichunmin/chameleon-ultra.js.git"
  },
  "resolutions": {
    "**/typescript": "^6",
    "**/jstransformer-scss": "^2.0.0"
  },
  "scripts": {
    "build": "yarn build:js && yarn build:cjsInterop && yarn build:docs && yarn build:pug && yarn build:sitemap",
    "build:cjsInterop": "tsx ./build-utils/cjsInterop.ts",
    "build:docs": "typedoc && tsx ./build-utils/typedoc.ts",
    "build:js": "tsup",
    "build:pug": "tsx ./pug/build.ts",
    "build:sitemap": "tsx ./build-utils/sitemap.ts",
    "dev": "DEBUG_COLORS=1 concurrently --names \"DOC,HTTPS,PUG,TS\" -c \"bgGray,bgGreen,bgGray,bgBlue,bgYellow\" \"yarn dev:docs\" \"yarn dev:https\" \"yarn dev:pug\" \"yarn dev:js\"",
    "dev:docs": "nodemon --watch src --watch documents --ext ts,md --exec \"yarn build:docs\"",
    "dev:https": "tsx ./build-utils/https.ts",
    "dev:js": "yarn build:js --watch",
    "dev:pug": "nodemon --watch pug --ext pug --exec \"yarn build:pug\"",
    "lint": "yarn lint:ci --fix",
    "lint:ci": "eslint",
    "mkcert": "mkdirp ./mkcert && mkcert -key-file ./mkcert/key.pem -cert-file ./mkcert/cert.pem -ecdsa localhost",
    "publish:test": "npm pack --dry-run",
    "test": "vitest -r ./src --testTimeout 180000",
    "test:ci": "yarn test --run --coverage"
  }
}
